{
    "compilerOptions": {
        "target": "ES2019",
        "module": "commonjs",
        "lib": [
            "ES2019"
        ],
        "outDir": "./dist",
        "rootDir": "./",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true
    },
    "include": [
        "nodes/**/*.ts",
        "index.ts"
    ],
    "exclude": [
        "node_modules",
        "dist",
        "**/__tests__/**",
        "**/*.test.ts"
    ]
}
